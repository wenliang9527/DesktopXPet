{
  "name": "蝴蝶忍 (Kocho Shinobu)",
  "author": "DesktopXPet",
  "version": "4.0.0",
  "preview": "preview.png",
  "description": "鬼灭之刃·蝴蝶忍 — 静态立绘 + 动态效果",
  "renderMode": "static",
  "frameSize": {
    "width": 128,
    "height": 128
  },
  "displayScale": 0.85,
  "animations": {
    "idle": {
      "effects": [
        { "type": "float", "speed": 1.0, "intensity": 3 },
        { "type": "breathe", "speed": 1.0, "intensity": 0.012 }
      ]
    },
    "working": {
      "effects": [
        { "type": "breathe", "speed": 1.5, "intensity": 0.01 }
      ]
    },
    "happy": {
      "effects": [
        { "type": "bounce", "speed": 2.0, "intensity": 6 },
        { "type": "sway", "speed": 1.5, "intensity": 0.03 }
      ],
      "duration": 3
    },
    "sleeping": {
      "effects": [
        { "type": "breathe", "speed": 0.5, "intensity": 0.02 },
        { "type": "float", "speed": 0.3, "intensity": 1.5 }
      ]
    },
    "error": {
      "effects": [
        { "type": "bounce", "speed": 3.0, "intensity": 5 },
        { "type": "sway", "speed": 2.0, "intensity": 0.05 }
      ]
    }
  }
}
