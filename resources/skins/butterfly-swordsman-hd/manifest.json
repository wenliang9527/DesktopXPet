{
  "name": "蝴蝶忍 HD (Kocho Shinobu HD)",
  "author": "DesktopXPet",
  "version": "5.0.0",
  "preview": "preview.png",
  "description": "鬼灭之刃·蝴蝶忍 HD — 静态立绘 + 动态效果",
  "renderMode": "static",
  "frameSize": {
    "width": 384,
    "height": 384
  },
  "displayScale": 0.85,
  "animations": {
    "idle": {
      "effects": [
        { "type": "float", "speed": 1.0, "intensity": 4 },
        { "type": "breathe", "speed": 1.0, "intensity": 0.012 }
      ]
    },
    "working": {
      "effects": [
        { "type": "breathe", "speed": 1.5, "intensity": 0.01 }
      ]
    },
    "happy": {
      "effects": [
        { "type": "bounce", "speed": 2.0, "intensity": 8 },
        { "type": "sway", "speed": 1.5, "intensity": 0.03 }
      ],
      "duration": 3
    },
    "jump": {
      "effects": [
        { "type": "float", "speed": 0.1, "intensity": 0.001 }
      ],
      "duration": 0.45
    },
    "sleeping": {
      "effects": [
        { "type": "breathe", "speed": 0.5, "intensity": 0.02 },
        { "type": "float", "speed": 0.3, "intensity": 2 }
      ]
    },
    "error": {
      "effects": [
        { "type": "bounce", "speed": 3.0, "intensity": 6 },
        { "type": "sway", "speed": 2.0, "intensity": 0.05 }
      ]
    }
  }
}
